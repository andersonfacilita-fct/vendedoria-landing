        Quero meu Vendedor IA · R$ 67<Icon name="arrow" class="h-5 w-5" />
      </a>
    </div>
    <script is:inline>
      (function () {
        var sticky = document.getElementById('sticky-cta'), offer = document.getElementById('oferta');
        if (!sticky || !offer) return;
        new IntersectionObserver(function (es) {
          es.forEach(function (e) { if (e.isIntersecting || e.boundingClientRect.top < 0) sticky.classList.remove('translate-y-full'); });
        }, { threshold: 0, rootMargin: '0px 0px -40% 0px' }).observe(offer);
      })();
