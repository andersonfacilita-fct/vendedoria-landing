    <div
      id="sticky-cta"
      class="fixed inset-x-0 bottom-0 z-50 translate-y-full border-t border-whats-green/30 bg-white/95 p-3 shadow-[0_-8px_24px_-12px_rgba(0,0,0,0.25)] backdrop-blur transition-transform duration-300 sm:hidden"
    >
