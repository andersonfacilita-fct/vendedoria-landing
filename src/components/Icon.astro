---
// Set de ícones SVG (outline, herda currentColor) pra substituir emojis.
export interface Props {
  name: string;
  class?: string;
}
const { name, class: className = 'h-6 w-6' } = Astro.props;

// paths em viewBox 24x24, stroke currentColor
const PATHS: Record<string, string> = {
  clock: '<circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/>',
  bolt: '<path d="M13 2L4 14h7l-1 8 9-12h-7l1-8z"/>',
  sparkle: '<path d="M12 3l1.6 4.6L18 9l-4.4 1.4L12 15l-1.6-4.6L6 9l4.4-1.4L12 3z"/><path d="M19 14l.8 2.2L22 17l-2.2.8L19 20l-.8-2.2L16 17l2.2-.8L19 14z"/>',
  chat: '<path d="M21 11.5a8.5 8.5 0 01-12.4 7.5L4 20l1-4.6A8.5 8.5 0 1121 11.5z"/>',
  help: '<circle cx="12" cy="12" r="9"/><path d="M9.5 9.5a2.5 2.5 0 014.9.7c0 1.7-2.4 2.3-2.4 3.8"/><path d="M12 17.5h.01"/>',
  calendar: '<rect x="4" y="5" width="16" height="16" rx="2"/><path d="M16 3v4M8 3v4M4 10h16"/><path d="M9.5 15l1.5 1.5 3-3"/>',
  flame: '<path d="M12 3c1 3-2 4-2 7a2 2 0 104 0c0 0 2 2 2 4a4 4 0 11-8 0c0-4 4-6 4-11z"/>',
  bell: '<path d="M6 9a6 6 0 1112 0c0 5 2 6 2 6H4s2-1 2-6z"/><path d="M10 20a2 2 0 004 0"/>',
  smile: '<circle cx="12" cy="12" r="9"/><path d="M8.5 14.5a4 4 0 007 0"/><path d="M9 9.6h.01M15 9.6h.01"/>',
  check: '<path d="M5 13l4 4L19 7"/>',
  shield: '<path d="M12 3l7 3v5c0 4.5-3 8-7 10-4-2-7-5.5-7-10V6l7-3z"/><path d="M9 12l2 2 4-4"/>',
  verified: '<path d="M12 3l2 2 2.8-.6.6 2.8 2 2-1.4 2.5L21 16l-2.4 1.3-.6 2.8L15 19.6 12 21l-3-1.4-2.8.6-.6-2.8L3 16l1.4-2.3L3 11.2l2-2L5.6 6.4 8.4 7 12 3z"/><path d="M9 12l2 2 4-4"/>',
  wallet: '<rect x="3" y="6" width="18" height="13" rx="2"/><path d="M16 12h.01M3 9h13a2 2 0 012 2"/>',
  nocode: '<path d="M9 8l-4 4 4 4M15 8l4 4-4 4"/><path d="M4 4l16 16"/>',
  lock: '<rect x="5" y="11" width="14" height="9" rx="2"/><path d="M8 11V8a4 4 0 018 0v3"/>',
  x: '<path d="M6 6l12 12M18 6L6 18"/>',
  store: '<path d="M4 9l1-4h14l1 4M5 9v10a1 1 0 001 1h12a1 1 0 001-1V9M4 9h16"/><path d="M9 20v-5h6v5"/>',
  play: '<circle cx="12" cy="12" r="9"/><path d="M10 9l5 3-5 3V9z" fill="currentColor" stroke="none"/>',
  star: '<path d="M12 3l2.6 5.6 6.1.8-4.5 4.2 1.2 6.1L12 17l-5.4 2.7 1.2-6.1L3.3 9.4l6.1-.8L12 3z" fill="currentColor" stroke="none"/>',
  arrow: '<path d="M13 7l5 5-5 5M18 12H6"/>',
