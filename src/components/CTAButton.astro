---
export interface Props {
  label?: string;
  sub?: string;
  size?: 'lg' | 'xl';
  fullWidth?: boolean;
  className?: string;
}

const {
  label = 'QUERO MEU VENDEDOR IA · R$ 67',
  sub = '',
  size = 'xl',
  fullWidth = true,
  className = '',
} = Astro.props;

// Checkout Hotmart — produto R106181710S (overlay via widget.min.js carregado no Layout)
const CHECKOUT_URL = 'https://pay.hotmart.com/R106181710S?checkoutMode=2';

// Separa a ação do preço (ex: "ATIVAR MEU VENDEDOR IA · R$ 67") pra o preço nunca quebrar sozinho
const [actionRaw, priceRaw] = label.split('·');
const action = (actionRaw || label).trim();
const price = priceRaw ? priceRaw.trim() : '';

const pad = {
  lg: 'px-5 py-3.5',
  xl: 'px-6 py-4 sm:px-8 sm:py-5',
};
const actionSize = {
  lg: 'text-sm sm:text-base',
  xl: 'text-base sm:text-lg lg:text-xl',
};
---

<div class={`flex flex-col items-center gap-2 ${fullWidth ? 'w-full' : ''} ${className}`}>
  <a
    href={CHECKOUT_URL}
    data-cta="checkout"
    class={`hotmart-fb hotmart__button-checkout group inline-flex items-center justify-center gap-2.5 rounded-2xl bg-gradient-to-br from-whats-green to-whats-green700 font-extrabold font-display uppercase tracking-wide text-white btn-glow-green transition-all duration-200 hover:-translate-y-0.5 active:translate-y-0 ${pad[size]} ${fullWidth ? 'w-full' : ''}`}
  >
    <svg class="h-6 w-6 flex-shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M12 2a10 10 0 00-8.6 15l-1.3 4.8 4.9-1.3A10 10 0 1012 2zm0 2a8 8 0 11-4.2 14.8l-.3-.2-2.9.8.8-2.8-.2-.3A8 8 0 0112 4zm-3.4 4.3c-.2 0-.5 0-.7.3-.3.3-1 .9-1 2.2s1 2.6 1.2 2.8c.1.2 2 3.1 4.9 4.3 2.4 1 2.9.8 3.4.8.5-.1 1.6-.7 1.9-1.3.2-.7.2-1.2.2-1.3-.1-.1-.3-.2-.6-.4-.3-.1-1.6-.8-1.9-.9-.2-.1-.4-.1-.6.1-.2.3-.7.9-.8 1-.2.2-.3.2-.6.1-.3-.2-1.2-.5-2.3-1.4-.8-.7-1.4-1.6-1.6-1.9-.1-.3 0-.4.1-.6l.5-.5c.1-.2.2-.3.3-.5 0-.2 0-.4 0-.5 0-.2-.6-1.5-.9-2-.2-.5-.4-.4-.6-.4z"/>
    </svg>
    <span class="flex min-w-0 flex-col items-center text-center leading-tight">
      <span class={`${actionSize[size]} text-balance`}>{action}</span>
      {price && <span class="mt-0.5 whitespace-nowrap text-sm font-bold tracking-normal text-white/95 sm:text-base">{price}</span>}
    </span>
    <svg class="hidden h-5 w-5 flex-shrink-0 transition-transform group-hover:translate-x-1 sm:block" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
    </svg>
  </a>
  <p class="mt-2 text-center text-xs font-semibold opacity-90 sm:text-sm">Compre agora e receba seu acesso no e-mail imediatamente!</p>
  <div class="mt-0.5 flex flex-wrap items-center justify-center gap-x-4 gap-y-1.5 text-[11px] font-medium opacity-75 sm:text-xs">
    <span class="inline-flex items-center gap-1.5">
      <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="11" width="14" height="9" rx="2"/><path d="M8 11V8a4 4 0 018 0v3"/></svg>
      Compra segura
    </span>
    <span class="inline-flex items-center gap-1.5">
      <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l7 3v5c0 4.5-3 8-7 10-4-2-7-5.5-7-10V6l7-3z"/></svg>
      Privacidade protegida
    </span>
    <span class="inline-flex items-center gap-1.5">
      <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 13l4 4L19 7"/></svg>
      Satisfação garantida
    </span>
  </div>
</div>
