---
export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = 'WhatsApp Vendedor IA Sem Complicação | Seu WhatsApp vendendo sozinho 24h',
  description =
    'Ative a IA oficial do WhatsApp pra atender, tirar dúvidas e agendar sozinha — 24h por dia, em 15 minutos, mesmo sem entender de tecnologia. Guia passo a passo por R$ 67.',
  ogImage = '/og-image.png',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();

// 🔧 Pixel ainda não criado pra este produto — preencher quando subir campanha.
// const PIXEL_ID = '';
---

<!doctype html>
<html lang="pt-BR" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="theme-color" content="#075E54" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site).toString()} />
    <meta property="og:locale" content="pt_BR" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site).toString()} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Plus+Jakarta+Sans:wght@600;700;800&display=swap"
      rel="stylesheet"
    />

    <!-- ============================================================= -->
    <!-- META PIXEL: placeholder. Quando o pixel deste produto existir, -->
    <!-- colar o snippet aqui e o handler de InitiateCheckout abaixo.    -->
    <!-- ============================================================= -->

    <!-- Structured Data - Product -->
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'Product',
        name: 'WhatsApp Vendedor IA Sem Complicação',
        description:
          'Guia passo a passo pra ativar e treinar a IA oficial do WhatsApp pra atender clientes, tirar dúvidas e agendar sozinha, 24h por dia.',
        brand: { '@type': 'Brand', name: 'WhatsApp Vendedor IA Sem Complicação' },
        offers: {
          '@type': 'Offer',
          price: '67.00',
          priceCurrency: 'BRL',
          availability: 'https://schema.org/InStock',
        },
      })}
    />
  </head>
  <body
    class="bg-white text-whats-ink font-sans antialiased selection:bg-whats-green/30 selection:text-whats-teal900"
  >
    <slot />

    <style is:global>
      html {
        -webkit-tap-highlight-color: transparent;
      }
      body {
        font-feature-settings: 'cv11', 'ss01';
      }
      .font-display {
        font-family: 'Plus Jakarta Sans', Inter, system-ui, sans-serif;
        letter-spacing: -0.02em;
      }
      /* gradiente verde escuro estilo header WhatsApp */
      .gradient-whats {
        background: linear-gradient(135deg, #075e54 0%, #0b6b5f 45%, #128c7e 100%);
      }
      .gradient-whats-soft {
        background: linear-gradient(160deg, #e7f7ef 0%, #f3fbf6 60%, #ffffff 100%);
      }
      .text-gradient-green {
        background: linear-gradient(90deg, #25d366 0%, #00a884 100%);
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-fill-color: transparent;
      }
      /* fundo de chat WhatsApp (textura sutil de pontos) */
      .chat-bg {
        background-color: #efeae2;
        background-image: radial-gradient(rgba(7, 94, 84, 0.06) 1px, transparent 1px);
        background-size: 18px 18px;
      }
      .btn-glow-green {
        box-shadow: 0 12px 28px -8px rgba(37, 211, 102, 0.55), 0 6px 12px -6px rgba(0, 168, 132, 0.35);
      }
      .btn-glow-green:hover {
        box-shadow: 0 20px 38px -8px rgba(37, 211, 102, 0.7), 0 10px 18px -6px rgba(0, 168, 132, 0.45);
      }
      /* balão de mensagem */
      .bubble-in,
      .bubble-out {
        position: relative;
        border-radius: 12px;
        padding: 8px 12px;
        font-size: 0.9rem;
        line-height: 1.3;
        box-shadow: 0 1px 1px rgba(11, 20, 26, 0.12);
      }
      .bubble-out {
        background: #d9fdd3;
      }
      .bubble-in {
        background: #ffffff;
      }
      @media (prefers-reduced-motion: reduce) {
        * {
          animation: none !important;
          transition: none !important;
        }
      }
    </style>
  </body>
</html>
