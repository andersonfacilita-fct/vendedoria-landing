---
export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = 'WhatsApp Vendedor IA Sem Complicação | Seu WhatsApp vendendo sozinho 24h',
  description =
    'Ative a IA oficial do WhatsApp pra atender, tirar dúvidas e agendar sozinha — 24h por dia, em 15 minutos, mesmo sem entender de tecnologia. Guia passo a passo por R$ 67.',
  ogImage = '/og-image.png',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();

// Meta Pixel — WhatsApp Vendedor IA Sem Complicação (BM Facilita Distribuidora 2026)
const PIXEL_ID = '1026788763199928';
---

<!doctype html>
<html lang="pt-BR" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="theme-color" content="#075E54" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site).toString()} />
    <meta property="og:locale" content="pt_BR" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site).toString()} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Plus+Jakarta+Sans:wght@600;700;800&display=swap"
      rel="stylesheet"
    />

    <!-- Meta Pixel — WhatsApp Vendedor IA (1026788763199928) -->
    <script is:inline define:vars={{ PIXEL_ID }}>
      !(function (f, b, e, v, n, t, s) {
        if (f.fbq) return;
        n = f.fbq = function () { n.callMethod ? n.callMethod.apply(n, arguments) : n.queue.push(arguments); };
        if (!f._fbq) f._fbq = n;
        n.push = n; n.loaded = !0; n.version = '2.0'; n.queue = [];
        t = b.createElement(e); t.async = !0; t.src = v;
        s = b.getElementsByTagName(e)[0]; s.parentNode.insertBefore(t, s);
      })(window, document, 'script', 'https://connect.facebook.net/en_US/fbevents.js');

      window.fbq('init', PIXEL_ID);
      window.fbq('track', 'PageView');
      // ViewContent imediato — sinal rápido pro algoritmo (Maxxima Fase 1)
      window.fbq('track', 'ViewContent', {
        content_name: 'WhatsApp Vendedor IA Sem Complicação',
        content_ids: ['R106181710S'], content_type: 'product',
        value: 67.0, currency: 'BRL',
      });
      // InitiateCheckout nos botões de compra (com sendBeacon p/ não perder em mobile)
      function wvEventId() {
        try { var k = 'wv_ic'; var v = sessionStorage.getItem(k);
          if (!v) { v = 'ic_' + Date.now() + '_' + Math.random().toString(36).slice(2, 10); sessionStorage.setItem(k, v); }
          return v; } catch (e) { return 'ic_' + Date.now(); }
      }
      window.addEventListener('DOMContentLoaded', function () {
        document.querySelectorAll('[data-cta="checkout"]').forEach(function (btn) {
          btn.addEventListener('click', function () {
            var eventID = wvEventId();
            window.fbq('track', 'InitiateCheckout', {
              content_name: 'WhatsApp Vendedor IA Sem Complicação',
              content_ids: ['R106181710S'], content_type: 'product',
              value: 67.0, currency: 'BRL', num_items: 1,
            }, { eventID: eventID });
            try {
              if (navigator.sendBeacon) {
                var body = new URLSearchParams({ id: PIXEL_ID, ev: 'InitiateCheckout',
                  cd: JSON.stringify({ value: 67, currency: 'BRL', content_ids: ['R106181710S'] }), eid: eventID });
                navigator.sendBeacon('https://www.facebook.com/tr/?' + body.toString());
              }
            } catch (e) {}
          });
        });
      });
    </script>
    <noscript>
      <img height="1" width="1" style="display:none" src={`https://www.facebook.com/tr?id=${PIXEL_ID}&ev=PageView&noscript=1`} />
    </noscript>

    <!-- Hotmart checkout widget (overlay) — produto R106181710S -->
    <script is:inline>
      (function () {
        var s = document.createElement('script');
        s.src = 'https://static.hotmart.com/checkout/widget.min.js';
        document.head.appendChild(s);
        var l = document.createElement('link');
        l.rel = 'stylesheet';
        l.type = 'text/css';
        l.href = 'https://static.hotmart.com/css/hotmart-fb.min.css';
        document.head.appendChild(l);
      })();
    </script>

    <!-- Structured Data - Product -->
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'Product',
        name: 'WhatsApp Vendedor IA Sem Complicação',
        description:
          'Guia passo a passo pra ativar e treinar a IA oficial do WhatsApp pra atender clientes, tirar dúvidas e agendar sozinha, 24h por dia.',
        brand: { '@type': 'Brand', name: 'WhatsApp Vendedor IA Sem Complicação' },
        offers: {
          '@type': 'Offer',
          price: '67.00',
          priceCurrency: 'BRL',
          availability: 'https://schema.org/InStock',
          url: 'https://pay.hotmart.com/R106181710S?checkoutMode=2',
        },
      })}
    />
  </head>
  <body
    class="bg-white text-whats-ink font-sans antialiased selection:bg-whats-green/30 selection:text-whats-teal900"
  >
    <slot />

    <style is:global>
      html {
        -webkit-tap-highlight-color: transparent;
      }
      body {
        font-feature-settings: 'cv11', 'ss01';
      }
      .font-display {
        font-family: 'Plus Jakarta Sans', Inter, system-ui, sans-serif;
        letter-spacing: -0.02em;
      }
      /* gradiente verde escuro estilo header WhatsApp */
      .gradient-whats {
        background: linear-gradient(135deg, #075e54 0%, #0b6b5f 45%, #128c7e 100%);
      }
      .gradient-whats-soft {
        background: linear-gradient(160deg, #e7f7ef 0%, #f3fbf6 60%, #ffffff 100%);
      }
      .text-gradient-green {
        background: linear-gradient(90deg, #25d366 0%, #00a884 100%);
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-fill-color: transparent;
      }
      /* fundo de chat WhatsApp (textura sutil de pontos) */
      .chat-bg {
        background-color: #efeae2;
        background-image: radial-gradient(rgba(7, 94, 84, 0.06) 1px, transparent 1px);
        background-size: 18px 18px;
      }
      .btn-glow-green {
        box-shadow: 0 12px 28px -8px rgba(37, 211, 102, 0.55), 0 6px 12px -6px rgba(0, 168, 132, 0.35);
      }
      .btn-glow-green:hover {
        box-shadow: 0 20px 38px -8px rgba(37, 211, 102, 0.7), 0 10px 18px -6px rgba(0, 168, 132, 0.45);
      }
      /* balão de mensagem */
      .bubble-in,
      .bubble-out {
        position: relative;
        border-radius: 12px;
        padding: 8px 12px;
        font-size: 0.9rem;
        line-height: 1.3;
        box-shadow: 0 1px 1px rgba(11, 20, 26, 0.12);
      }
      .bubble-out {
        background: #d9fdd3;
      }
      .bubble-in {
        background: #ffffff;
      }
      @media (prefers-reduced-motion: reduce) {
        * {
          animation: none !important;
          transition: none !important;
        }
      }
    </style>
  </body>
</html>
